# Django secret key (required)
DJANGO_SECRET_KEY=your-secret-key-here

# Debug mode (set to False in production)
DJANGO_DEBUG=False

# Comma-separated list of allowed hosts in production
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# CORS allowed origins in production (comma-separated, e.g. https://rentgrid.ng,https://www.rentgrid.ng)
# Leave blank in development to allow localhost origins automatically
CORS_ALLOWED_ORIGINS=

# Database (uses SQLite if not set)
DATABASE_URL=postgresql://user:password@localhost:5432/rentgrid
DATABASE_SSL=false

# Cache — used by django-ratelimit. In production, set REDIS_URL for shared cache.
# Leave blank to use database cache (no Redis needed in development).
REDIS_URL=

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Payments
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_HASH=

# Email & SMS notifications
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=RentGrid <support@rentgrid.ng>
SENDGRID_API_KEY=
TERMII_API_KEY=
TERMII_SENDER_ID=RentGrid
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Observability
NEXT_PUBLIC_ANALYTICS_KEY=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_TRACES_SAMPLE_RATE=0.2

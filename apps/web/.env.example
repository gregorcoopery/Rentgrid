# ─────────────────────────────────────────────────────────────────────────────
# RentGrid — Frontend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — only .env.example is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# Django backend URL (Next.js rewrites all /api/* calls here)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# ─── Clerk Authentication (required) ─────────────────────────────────────────
# Get these from: https://clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# ─── Payments (at least one required for live transactions) ──────────────────
# Paystack: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Flutterwave (optional alternative): https://app.flutterwave.com/settings/apis
FLUTTERWAVE_SECRET_KEY=
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_HASH=

# ─── Email Notifications ─────────────────────────────────────────────────────
# Resend: https://resend.com → API Keys
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=RentGrid <support@rentgrid.ng>

# Sendgrid (optional alternative)
SENDGRID_API_KEY=

# ─── SMS Notifications ───────────────────────────────────────────────────────
# Termii (Nigerian SMS): https://termii.com → Settings → API
TERMII_API_KEY=
TERMII_SENDER_ID=RentGrid

# Twilio (optional alternative)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ─── Observability ───────────────────────────────────────────────────────────
# Sentry: https://sentry.io → Create Project → DSN
NEXT_PUBLIC_ANALYTICS_KEY=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_TRACES_SAMPLE_RATE=0.2
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.2
NEXT_PUBLIC_SENTRY_REPLAY_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAY_ERROR_SAMPLE_RATE=1.0

# ─── Database (if using direct Postgres connection from Next.js) ──────────────
DATABASE_URL=postgresql://rentgrid_user:password@localhost:5432/rentgrid
DATABASE_SSL=false
